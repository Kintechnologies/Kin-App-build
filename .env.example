# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Web Search (Tavily — free tier at tavily.com)
TAVILY_API_KEY=your-tavily-api-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Google Calendar (console.cloud.google.com > APIs > Calendar API)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_WEBHOOK_SECRET=your-google-webhook-secret

# RevenueCat (revenuecat.com > Project Settings > Webhooks)
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# Cron (generate a random secret, e.g. openssl rand -hex 32)
CRON_SECRET=your-cron-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
