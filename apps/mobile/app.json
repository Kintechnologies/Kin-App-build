{
  "expo": {
    "name": "Kin",
    "slug": "kin-family-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "kin",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0F0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "family.kinai.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Kin uses speech recognition for voice input",
        "NSMicrophoneUsageDescription": "Kin needs microphone access for voice input",
        "NSPhotoLibraryUsageDescription": "Kin can analyze photos you share",
        "NSCameraUsageDescription": "Kin can analyze photos from your camera"
      }
    },
    "android": {
      "package": "family.kinai.app",
      "adaptiveIcon": {
        "backgroundColor": "#0C0F0A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-image-picker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9bd27e0d-dcc6-4b23-98d3-65dbbcde75f7"
      }
    }
  }
}
