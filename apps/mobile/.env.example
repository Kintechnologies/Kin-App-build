# Kin Mobile — Environment Variables
# Copy this file to .env and fill in the values.
# All EXPO_PUBLIC_ vars are bundled into the app and visible to end users.
# Never put secrets (service role keys, private tokens) in EXPO_PUBLIC_ vars.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe to expose to the client
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── API ───────────────────────────────────────────────────────────────────────
# Base URL for the Kin web API (Next.js app). In production: https://kinai.family
EXPO_PUBLIC_API_URL=https://kinai.family

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Public SDK key from RevenueCat dashboard → API Keys → Apple (iOS)
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_...

# ── Sentry ────────────────────────────────────────────────────────────────────
# DSN from Sentry project settings. Optional — Sentry is silently disabled if unset.
EXPO_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
