# Kin AI — Environment Variables
# Copy to .env.local and fill in your values

# ============================================================================
# SUPABASE (Database, Auth, Edge Functions)
# ============================================================================

# Get from Supabase project settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service key — SERVER-SIDE ONLY, never in client app
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# ANTHROPIC (Claude API for Kin AI)
# ============================================================================

# Get from Anthropic console
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# GOOGLE OAUTH (For Google Sign-In and Calendar)
# ============================================================================

# Get from Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth scopes (in Supabase Auth config, NOT in app)
# For auth: https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/userinfo.profile openid
# For calendar: separate explicit OAuth grant at runtime

# ============================================================================
# APPLE SIGN-IN (For iOS)
# ============================================================================

# Get from Apple Developer account
APPLE_TEAM_ID=your-team-id
APPLE_BUNDLE_ID=com.kinai.family

# ============================================================================
# MAPS & COMMUTE (Optional for Phase 2)
# ============================================================================

# Apple Maps (for iOS native commute)
APPLE_MAPS_KEY=your-apple-maps-key

# Google Maps (for Android commute)
GOOGLE_MAPS_API_KEY=your-google-maps-key

# ============================================================================
# REVENUECAT (For in-app subscriptions)
# ============================================================================

# Get from RevenueCat dashboard
REVENUECAT_PUBLIC_KEY=appl_your-public-key

# ============================================================================
# EXPO CONFIGURATION
# ============================================================================

# EAS project ID (for build & push notifications)
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# ============================================================================
# SENTRY (Error tracking — optional)
# ============================================================================

SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=kin-mobile

# ============================================================================
# INTERNAL DEVELOPMENT FLAGS
# ============================================================================

# Set to true to enable verbose logging
DEBUG=false

# Set to true to use seed data on launch
USE_SEED_DATA=false

# Briefing generation endpoint (for testing)
BRIEFING_ENDPOINT=http://localhost:54321/functions/v1/morning-briefing
