{
  "name": "kin-monorepo",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @kin/web",
    "build:web": "npm run build -w @kin/web",
    "dev:mobile": "npm run start -w @kin/mobile",
    "test": "vitest run --workspace vitest.workspace.ts",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "test:shared": "npm run test -w @kin/shared",
    "test:web": "npm run test -w @kin/web"
  },
  "devDependencies": {
    "vitest": "latest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0"
  }
}
